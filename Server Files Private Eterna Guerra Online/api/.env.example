# Opción 1 (recomendada): construir conexión automáticamente (sin contraseña, Windows)
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=EternaGuerraAuth
DB_AUTH_MODE=trusted
DB_USER=ECOSEA-DO\SQLEXPRESS
DB_PASSWORD=
DB_DRIVER=ODBC Driver 18 for SQL Server

# Opción 2: string completa manual (si se define, tiene prioridad)
DB_CONNECTION_STRING=

API_PORT=8080
WORLD_IP=127.0.0.1
WORLD_PORT=5999
GAME_SERVER_IP=127.0.0.1
GAME_SERVER_PORT=7000
EMULATOR_PORTS=5999,7000,6000,29000

EMULATOR_MODE=hybrid
EMULATOR_LOG_PACKETS=1
EMULATOR_LOG_FILE=logs/world_emulator_packets.log
EMULATOR_SEND_HELLO_ON_CONNECT=1
EMULATOR_HELLO_SEQUENCE_HEX=47 57 68 7C
EMULATOR_HELLO_TEXT=SYSTEM_ONLINE\n
EMULATOR_BINARY_REPLY_MODE=mirror_first
EMULATOR_BINARY_REPLY_HEX=47 57 68 7C
EMULATOR_ENABLE_UDP=1
EMULATOR_UDP_REPLY_HEX=47 57 68 7C

# Opcional: catálogo de regiones/servidores para launcher moderno (JSON array en una línea)
REGION_SERVER_DIRECTORY_JSON=
